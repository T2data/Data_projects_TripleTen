    <dashboard enable-sort-zone-taborder='true' name='Occupation vs. Purchasing Behavior'>
      <style />
      <size maxheight='651' maxwidth='1350' minheight='651' minwidth='1350' preset-index='17' sizing-mode='fixed' />
      <zones>
        <zone forceUpdate='true' h='35023' id='4' type-v2='text' w='55111' x='296' y='8909'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman' fontsize='14'>Findings:</run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Æ </run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Zomato users are predominantly students and working professionals, with minimal representation from housewives.</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman' fontsize='14'>Recommendations:</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Æ </run>
            <run fontcolor='#0a0a0a' fontname='Times New Roman' fontsize='12'>Zomato should diversify its marketing by creating tailored campaigns for employees, continuing to target students, and utilizing research to understand the homemaker segment better.</run>
