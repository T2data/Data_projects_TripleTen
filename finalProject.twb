      <simple-id uuid='{3919A00E-62C4-4B48-B8B1-E29F697DE306}' />
    </dashboard>
    <dashboard name='Zomato Story ' type='storyboard'>
      <style>
        <style-rule element='story-description'>
          <format attr='border-width' id='story-description_6' value='0' />
          <format attr='border-style' id='story-description_6' value='none' />
          <format attr='border-width' id='story-description_7' value='0' />
          <format attr='border-style' id='story-description_7' value='none' />
          <format attr='background-color' id='story-description_6' value='#ffffffd9' />
        </style-rule>
        <style-rule element='story-point-caption'>
          <format attr='width' value='179' />
        </style-rule>
      </style>
      <size maxheight='768' maxwidth='1366' minheight='768' minwidth='1366' preset-index='0' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='97916' id='1' param='vert' removable='false' type-v2='layout-flow' w='98828' x='586' y='1042'>
            <zone h='13151' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98828' x='586' y='1042' />
            <zone h='84765' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98828' x='586' y='14193'>
              <flipboard active-id='4' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Zomato User Demographics' captured-sheet='Zomato Dashboard' id='4'>
                    <currentDeltas>
                      <worksheet name='Monthly Income'>
                        <datasource-dependencies datasource='federated.09phax50r6mr6f17srpy60gd67c1'>
                          <column caption='C' datatype='date' name='[order_date]' role='dimension' type='ordinal' />
                          <column caption='Status' datatype='string' name='[Calculation_2165387059698626599]' role='dimension' type='nominal'>
                            <calculation class='tableau' formula='IF [order_date]&lt; DATEADD(&apos;day&apos;,-180,DATE(&apos;6/23/2020&apos;)) THEN &quot;Inactive&quot;&#13;&#10;ELSE &quot;active&quot;&#13;&#10;END&#13;&#10; //DATEADD(&apos;day&apos;,-90,[C])' />
                          </column>
                          <column-instance column='[Calculation_2165387059698626599]' derivation='None' name='[none:Calculation_2165387059698626599:nk]' pivot='key' type='nominal' />
                        </datasource-dependencies>
                        <filter class='categorical' column='[federated.09phax50r6mr6f17srpy60gd67c1].[none:Calculation_2165387059698626599:nk]'>
                          <groupfilter function='level-members' level='[none:Calculation_2165387059698626599:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
                        </filter>
                      </worksheet>
                    </currentDeltas>
                    <capturedDeltas>
                      <worksheet name='Occupation'>
                        <selection-collection />
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Age' captured-sheet='Age vs. Purchasing Behavior' id='6'>
                    <capturedDeltas>
                      <dashboard name='Age vs. Purchasing Behavior'>
                        <zone id='4'>
                          <formatted-text>
                            <run bold='true' fontcolor='#000000' fontname='Times New Roman' fontsize='14'>Findings:</run>
                            <run bold='true' fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Æ </run>
                            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Zomato&apos;s core audience spans 18–33 year-olds, with peak engagement among the 22–26 demographic. Twenty-three-year-olds are the highest spenders and most frequent users.</run>
                            <run>Æ&#10;&#10;</run>
                            <run bold='true' fontcolor='#000000' fontname='Times New Roman' fontsize='14'>Recommendations:</run>
                            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'> To drive expansion, marketing initiatives should focus on boosting engagement with the 18–21 and 27–33 age demographics, while sustaining current strategies for the 22–26 group. Furthermore, conducting a deeper analysis of customer feedback is crucial to identifying why other segments spend less, which will guide future retention and advertising strategies.</run>
                          </formatted-text>
                        </zone>
                      </dashboard>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Family Size' captured-sheet='Family Size vs. Purchasing Behavior' id='7' />
                  <story-point caption='Gender' captured-sheet='Gender vs. Purchasing Behavior' id='8'>
                    <capturedDeltas>
                      <dashboard name='Gender vs. Purchasing Behavior'>
                        <zone id='4'>
                          <formatted-text>
                            <run bold='true' fontcolor='#000000' fontname='Times New Roman' fontsize='14'>Findings:</run>
                            <run bold='true' fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Æ </run>
                            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>While male users show higher overall engagement with more orders and higher expenditure, female users tend to have a slightly higher average order value.</run>
                            <run>Æ&#10;&#10;</run>
                            <run bold='true' fontcolor='#000000' fontname='Times New Roman' fontsize='14'>Recommendations:</run>
                            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'> To boost engagement among female users, Zomato should utilize targeted feedback tools and personalized marketing focused on value-driven, exclusive restaurant partnerships. By applying customized advertising and incentivizing feedback, Zomato can improve user satisfaction and strengthen its customer base within this demographic.</run>
                          </formatted-text>
                        </zone>
                      </dashboard>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Marital Status' captured-sheet='Marital Status vs. Purchasing Behavior' id='9' />
                  <story-point caption='Monthly Income' captured-sheet='Monthly Income vs. Purchasing Behavior' id='10' />
                  <story-point caption='Occupation' captured-sheet='Occupation vs. Purchasing Behavior' id='11' />
                  <story-point caption='conclusions and recommendations' captured-sheet='' id='12' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='88151' hidden='true' id='6' story-point-id='12' type-v2='text' w='98389' x='1830' y='12109'>
          <formatted-text>
            <run bold='true' fontcolor='#000000d3' fontname='Times New Roman'>Conclusions and Recommendations</run>
            <run>Æ&#10;</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Times New Roman'>Conclusions: </run>
            <run fontalignment='0' fontcolor='#000000' fontname='Times New Roman'>Zomato’s core users are heavily concentrated among young, unmarried individuals, including students and young professionals, with a strong representation of small households (2 to 3 members). A significant portion of this group has limited or no income, with the smallest group earning less than Rs. 10,000 monthly. Customer segmentation analysis indicates a need for expansion to increase engagement, boost order volume, and drive growth.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Times New Roman'>Summary of Recommendations: </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Symbol' fontsize='15'>·</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Symbol' fontsize='11'>Æ </run>
            <run fontalignment='0' fontcolor='#000000' fontname='Times New Roman' fontsize='15'>Zomato should shift its marketing strategy to attract a more diverse user base, including female consumers, a broader age range,</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Times New Roman'> higher earners, and single-person households.</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Symbol' fontsize='15'>· </run>
            <run fontalignment='0' fontcolor='#000000' fontname='Times New Roman,serif' fontsize='15'>Develop family-friendly deals and tailored marketing messages specifically designed to attract married couples and larger households.</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='15'>Æ </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Symbol' fontsize='15'>· </run>
            <run fontalignment='0' fontcolor='#000000' fontname='Times New Roman,serif' fontsize='15'>Implement customized promotional initiatives for the 18-21 and 27-33 age cohorts, while maintaining current strategies for the core 22–26-year-olds.</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='15'>Æ </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Symbol' fontsize='15'>·</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Symbol' fontsize='11'>Æ </run>
            <run fontalignment='0' fontcolor='#000000' fontname='Times New Roman,serif' fontsize='15'>Use specialized questionnaires to gather data on user satisfaction, and conduct a systematic analysis of customer feedback from underperforming segments to pinpoint why they spend less.</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='15'>Æ </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Symbol' fontsize='15'>· </run>
            <run fontalignment='0' fontcolor='#000000' fontname='Times New Roman,serif' fontsize='15'>Design custom marketing streams for working professionals and students, while initiating specialized market research to unlock the potential of the homemaker segment</run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{9FED91BB-08D9-4AC7-BE29-8D0C5CC7CB40}' />
    </dashboard>
  </dashboards>
