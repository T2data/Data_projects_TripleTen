    <dashboard enable-sort-zone-taborder='true' name='Marital Status vs. Purchasing Behavior'>
      <style />
      <size maxheight='651' maxwidth='1350' minheight='651' minwidth='1350' preset-index='17' sizing-mode='fixed' />
      <zones>
        <zone forceUpdate='true' h='37942' id='4' type-v2='text' w='56296' x='296' y='8909'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman' fontsize='14'>Findings:</run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Æ </run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>High-frequency ordering and significant spending on Zomato are driven primarily by single users, ordering more often and spending more in total than married customers</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman' fontsize='14'>Recommendations:</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'> To drive deeper customer engagement, Zomato should focus advertising efforts on the married demographic. Moreover, initiatives aimed at encouraging users of all relationship statuses to leave more reviews should be implemented to generate superior customer insights. </run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='6912' id='5' type-v2='text' w='39259' x='28074' y='614'>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Times New Roman' fontsize='14'>Marital Status Vs Purchasing Behavior </run>
          </formatted-text>
        </zone>
        <zone h='41014' id='37' name='Marital Status vs Average Spending' show-title='false' w='39111' x='57778' y='8756' />
        <zone h='47619' id='39' name='Marital Status vs Purchase Frequency' show-title='false' w='49852' x='1185' y='51306' />
