      <aliases enabled='yes' />
      <column aggregation='None' caption='Age (bin)' datatype='integer' name='[Age (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='0' formula='[Age]' peg='0' size='5' />
      </column>
      <column datatype='integer' name='[Age]' role='measure' type='quantitative' />
      <column caption='Average - Spend' datatype='real' name='[Average Spend (copy)_1087056428111507457]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [user_id (orders.csv)] : AVG([sales_amount])}&#13;&#10;//{ FIXED [User Id] : AVG([Sales Amount])}&#13;&#10;//SUM([Sales Amount])/COUNTD([User Id])' />
      </column>
      <column caption='Calc_active_users  (copy)' datatype='string' name='[Calc_active_users  (copy)_2165387058956525600]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Data Blending or Joins (Best for Separate User/Order Tables)&#13;&#10;&#13;&#10;IF [order_date] &gt;= {MAX([order_date])}-90 THEN &quot;Active&quot; ELSE &quot;Inactive&quot; END' />
      </column>
      <column caption='Total User' datatype='integer' name='[Calculation_2165387056101351424]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([user_id (orders.csv)])' />
      </column>
      <column caption='Gendercalc' datatype='string' name='[Calculation_2165387056434909186]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Gender]=&quot;Male&quot; THEN &quot;Men&quot; ELSE &quot;Women&quot; END' />
      </column>
      <column caption='Date Trunc' datatype='datetime' name='[Calculation_2165387057038565379]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC([Parameters].[Parameter 2],[order_date])' />
      </column>
      <column caption='Calc_active_users ' datatype='string' name='[Calculation_2165387057403502607]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Data Blending or Joins (Best for Separate User/Order Tables)&#13;&#10;//Since the data is old I don&apos;t want to use this formula for now&#13;&#10;//IF [C]&lt; DATEADD(&apos;day&apos;,-180,DATE(&apos;6/23/2020&apos;)) THEN &quot;Inactive&quot;&#13;&#10;//ELSE &quot;active&quot;&#13;&#10;//END&#13;&#10;&#13;&#10;{ FIXED [user_id] : MAX(IF NOT ISNULL([r_id]) THEN &quot;Ordered&quot; ELSE &quot;No Order&quot; END) }' />
      </column>
      <column aggregation='Count' caption='R Id_0' datatype='integer' datatype-customized='true' name='[Calculation_2165387058216124435]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL([r_id],0)' />
      </column>
      <column caption='Purchase Frequency' datatype='integer' name='[Calculation_2165387058247626773]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='//COUNT([R Id_0])/COUNTD([User Id (Orders.Csv)])&#13;&#10;//{ FIXED [User Id] :COUNTD([R Id_0])}&#13;&#10;{ FIXED [user_id] :COUNT([user_id (orders.csv)])}' />
      </column>
      <column caption='AOV' datatype='real' name='[Calculation_2165387058248339478]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales_amount])/COUNTD([Calculation_2165387058216124435])' />
      </column>
      <column caption='Total Spend' datatype='integer' name='[Calculation_2165387058249170967]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='//Total spend (Lifetime Value)&#13;&#10;{ FIXED [user_id] : SUM([sales_amount])}' />
      </column>
      <column caption='testTotalspend' datatype='integer' name='[Calculation_2165387058259226648]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales_amount])' />
      </column>
      <column caption='Remove null Order Id' datatype='integer' name='[Calculation_2165387058582016025]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF NOT ISNULL([r_id]) THEN [r_id] END' />
      </column>
      <column caption='removeDupOrderId' datatype='integer' name='[Calculation_2165387058585411610]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [r_id]:MIN([r_id])}' />
      </column>
      <column caption='countUserFromOrder' datatype='integer' name='[Calculation_2165387058914422812]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([user_id (orders.csv)])' />
      </column>
      <column caption='AgeGroup_calc' datatype='string' name='[Calculation_2165387059576627233]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF  [Age] &lt;21 THEN &quot;18 - 20&quot; &#13;&#10;ELSEIF [Age]&lt;24 THEN &quot;21 - 23&quot; &#13;&#10;ELSEIF [Age] &lt; 27 THEN &quot;24 - 26&quot;&#13;&#10;ELSEIF [Age] &lt; 30 THEN &quot;27 - 29&quot;&#13;&#10;ELSE  &quot;Over 30&quot;&#13;&#10;END' />
      </column>
      <column caption='income Bands' datatype='string' name='[Calculation_2165387059647242275]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF  [Monthly Income] =&quot;More than 50000&quot; THEN &quot;High (&gt;50k)&quot;&#13;&#10;ELSEIF [Monthly Income]= &quot;25001 to 50000&quot; THEN &quot;Mid (25k - 50K)&quot;&#13;&#10;ELSEIF  [Monthly Income]= &quot;10001 to 25000&quot; THEN &quot;Low (&lt;25k)&quot;&#13;&#10;ELSEIF  [Monthly Income]=&quot;Below Rs.10000&quot; THEN &quot;Below Rs.10000&quot;&#13;&#10;ELSE &quot;No income&quot;&#13;&#10;END' />
      </column>
      <column caption='Status' datatype='string' name='[Calculation_2165387059698626599]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [order_date]&lt; DATEADD(&apos;day&apos;,-180,DATE(&apos;6/23/2020&apos;)) THEN &quot;Inactive&quot;&#13;&#10;ELSE &quot;active&quot;&#13;&#10;END&#13;&#10; //DATEADD(&apos;day&apos;,-90,[C])' />
      </column>
      <column caption='Average Spend' datatype='real' name='[Calculation_2756484511807561728]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [user_id (orders.csv)] : AVG([sales_amount])}&#13;&#10;//{ FIXED [User Id] : AVG([Sales Amount])}&#13;&#10;//SUM([Sales Amount])/COUNTD([User Id])' />
      </column>
      <column caption='duplicateCalc' datatype='boolean' name='[Calculation_2756484512116510721]' role='dimension' type='nominal'>
