  <dashboards>
    <dashboard enable-sort-zone-taborder='true' name='Age vs. Purchasing Behavior'>
      <style />
      <size maxheight='651' maxwidth='1350' minheight='651' minwidth='1350' preset-index='17' sizing-mode='fixed' />
      <zones>
        <zone h='48958' id='1' name='Age vs Pruchase Frequecny' show-title='false' w='48170' x='952' y='51823' />
        <zone h='37174' id='2' name='Age vs Average Spending' show-title='false' w='34815' x='64815' y='10753' />
        <zone h='50998' id='3' name='Age vs Total Spending' show-title='false' w='47926' x='51407' y='48848' />
        <zone forceUpdate='true' h='42243' id='4' type-v2='text' w='60444' x='296' y='8909'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman' fontsize='14'>Findings:</run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Æ </run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Zomato&apos;s core audience spans 18–33 year-olds, with peak engagement among the 22–26 demographic. Twenty-three-year-olds are the highest spenders and most frequent users.</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman' fontsize='14'>Recommendations:</run>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12'> To drive expansion, marketing initiatives should focus on boosting engagement with the 18–21 and 27–33 age demographics, while sustaining current strategies for the 22–26 group. Furthermore, a deeper analysis of customer feedback is essential to understand the reasons for lower spending in other segments, thereby informing future retention and advertising efforts.</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='6912' id='5' type-v2='text' w='28222' x='39111' y='614'>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Times New Roman' fontsize='14'>Age Vs Purchasing Behavior </run>
          </formatted-text>
        </zone>
      </zones>
      <devicelayouts>
        <devicelayout auto-generated='true' name='Phone'>
          <size maxheight='1000' minheight='1000' sizing-mode='vscroll' />
          <zones>
            <zone h='100000' id='111' type-v2='layout-basic' w='100000' x='0' y='0'>
